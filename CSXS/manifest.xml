<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="9.0" ExtensionBundleId="studio.kage"
    ExtensionBundleVersion="2.1.0"
    ExtensionBundleName="Kage Studio"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <ExtensionList>
        <Extension Id="studio.kage.panel" Version="2.1.0" />
    </ExtensionList>
    <ExecutionEnvironment>
        <HostList>
            <Host Name="AEFT" Version="[22.0,99.9]" />
        </HostList>
        <LocaleList>
            <Locale Code="All" />
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="9.0" />
        </RequiredRuntimeList>
    </ExecutionEnvironment>
    <DispatchInfoList>
        <Extension Id="studio.kage.panel">
            <DispatchInfo>
                <Resources>
                    <MainPath>./client/index.html</MainPath>
                    <ScriptPath>./host/import.jsx</ScriptPath>
                    <CEFCommandLine>
                        <Parameter>--enable-nodejs</Parameter>
                        <Parameter>--mixed-context</Parameter>
                        <Parameter>--disable-web-security</Parameter>
                        <Parameter>--allow-file-access-from-files</Parameter>
                        <Parameter>--autoplay-policy=no-user-gesture-required</Parameter>
                    </CEFCommandLine>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>Kage Studio</Menu>
                    <Geometry>
                        <Size>
                            <Height>600</Height>
                            <Width>420</Width>
                        </Size>
                        <MinSize>
                            <Height>360</Height>
                            <Width>320</Width>
                        </MinSize>
                        <MaxSize>
                            <Height>2400</Height>
                            <Width>1800</Width>
                        </MaxSize>
                    </Geometry>
                    <Icons />
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>
